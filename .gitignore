# Python 가상환경
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── 환경 변수 (API 키 포함 — 절대 커밋 금지) ─────────────────
.env
.env.local
.env.*.local

# ── 데이터베이스 (개인정보·암호화 데이터 포함) ───────────────
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ── 런타임 로그 및 에러 로그 (민감 정보 포함 가능) ───────────
data/logs/
data/fix_error/

# ── 자동 생성 리포트 (내부 운영 수치) ────────────────────────
data/maintenance_reports/

# ── 원본 PDF 및 추출 텍스트 (저작권·개인정보) ────────────────
data/raw_pdf/
data/raw_text/
data/student/

# ── PID 파일 ─────────────────────────────────────────────────
data/pids/

# ── 백업 아카이브 (대용량 — 원격 저장소 별도 관리) ──────────
data/backups/

# ── 폰트 바이너리 ─────────────────────────────────────────────
data/fonts/

# ── 훈련 데이터 (대용량 JSONL) ────────────────────────────────
data/training/

# ── 런타임 상태 파일 (재시작마다 덮어씌워짐) ─────────────────
system_config.json

# ── 백업/임시 파일 ────────────────────────────────────────────
*.bak
*.tmp
*.orig

# ── macOS ─────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
